# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Optional: Bot username (without @)
BOT_USERNAME=your_bot_username

# Optional: Webhook URL for production deployment
# Leave empty to use polling mode
WEBHOOK_URL=https://yourdomain.com/webhook

# Database Configuration
# SQLite database file path (default: chat_statistics.db)
DATABASE_PATH=chat_statistics.db

# Statistics Settings
# Maximum messages to store per chat (default: 10000)
MAX_MESSAGES_PER_CHAT=10000

# How often to clean up old messages in seconds (default: 300 = 5 minutes)
STATS_UPDATE_INTERVAL=300